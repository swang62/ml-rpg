{
  "name": "system-overflow",
  "type": "module",
  "scripts": {
    "dev": "vinxi dev",
    "build": "vinxi build",
    "preview": "vinxi serve --dir .output/public",
    "prepare": "husky || true",
    "lint": "biome check --write ."
