{
  "name": "ml-rpg",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "cd apps/web && vinxi build",
    "build:docker": "docker compose up --build --force-recreate -d",
    "build:finetune": "just default",
    "dev": "./apps/web/scripts/start-dev.sh",
    "generate:types": "rm -f ./apps/web/src/db/*.ts && sqlc generate",
    "lint": "biome check --write --unsafe . && pnpm typecheck && uv run basedpyright apps/rag-api/rag_api/ apps/llama-api/llama_api/",
    "preview": "cd apps/web && dotenv -- vinxi start",
    "prepare": "husky || true",
    "scrape": "dotenv -- tsx ./apps/web/scripts/scrape-lessons.ts",
    "seed": "dotenv -- tsx ./apps/web/scripts/seed-db.ts",
    "test": "cd apps/web && vitest run && cd ../.. && pnpm test:python",
    "test:python": "uv run --group dev pytest apps/rag-api/rag_api/__tests__ apps/llama-api/llama_api/__tests__ -v",
    "typecheck": "cd apps/web && pnpm tsc --noEmit"
  },
  "dependencies": {
    "@lancedb/lancedb": "^0.27.2",
    "@langchain/textsplitters": "^1.0.1",
    "@solidjs/meta": "^0.29.4",
    "@solidjs/router": "^0.15.0",
    "@solidjs/start": "1.3.2",
    "argon2": "^0.44.0",
    "better-sqlite3": "^12.10.0",
    "isomorphic-dompurify": "^3.13.0",
    "lucide-solid": "^1.14.0",
    "minisearch": "^7.2.0",
    "node-cron": "3.0.3",
    "solid-js": "1.9.12",
    "vinxi": "^0.5.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.14",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.6.2",
    "@types/node-cron": "3.0.11",
    "dotenv-cli": "^11.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.2",
    "node-html-parser": "^7.1.0",
    "postcss": "^8.5.14",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.13",
    "vitest": "^4.1.6"
  },
  "lint-staged": {
    "*.{js,ts,jsx,tsx,json,jsonc,css,html,md,yml,yaml}": [
      "biome check --write --unsafe --no-errors-on-unmatched",
      "cd apps/web && vitest related --run --reporter=verbose"
    ],
    "!apps/web/src/db/*_sql.ts": [],
    "**/test_*.py": [
      "uv run --group dev pytest apps/rag-api/rag_api/__tests__ apps/llama-api/llama_api/__tests__ -v"
    ]
  },
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@11.2.2+sha512.36e6621fad506178936455e70247b8808ef4ec25797a9f437a93281a020484e2607f6a469a22e982987c3dbb8866e3071514ab10a4a1749e06edcd1ec118436f"
}
