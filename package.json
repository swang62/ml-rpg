    "@solidjs/router": "^0.15.0",
    "@solidjs/start": "1.3.2",
    "solid-js": "^1.9.5",
    "vinxi": "^0.5.7"
  },
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.14",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.2"
  }
}
