{
  "name": "ml-rpg",
  "type": "module",
  "scripts": {
    "build": "vinxi build",
    "build:docker": "docker compose up --build --force-recreate -d",
    "dev": "vinxi dev",
    "generate:types": "rm -f ./src/db/*.ts && sqlc generate",
    "lint": "biome check --write . && pnpm typecheck",
    "preview": "vinxi start",
    "prepare": "husky || true",
    "seed": "tsx ./scripts/seed.ts",
    "typecheck": "pnpm tsc --noEmit"
  },
  "dependencies": {
    "@fontsource-variable/plus-jakarta-sans": "^5.2.8",
    "@fontsource/press-start-2p": "^5.2.7",
    "@solidjs/meta": "^0.29.4",
    "@solidjs/router": "^0.15.0",
    "@solidjs/start": "1.3.2",
    "better-sqlite3": "^12.10.0",
    "lucide-solid": "^1.14.0",
    "minisearch": "^7.2.0",
    "solid-js": "^1.9.5",
    "vinxi": "^0.5.7"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.14",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.6.2",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.2",
    "postcss": "^8.5.14",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.13"
  },
  "lint-staged": {
    "*.{js,ts,jsx,tsx,json,jsonc,css,html,md,yml,yaml}": "biome check --write --no-errors-on-unmatched",
    "!src/db/*_sql.ts": ""
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@11.1.0"
}
