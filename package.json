{
  "name": "system-overflow",
  "type": "module",
  "scripts": {
    "build": "vinxi build",
    "build:search": "tsx scripts/build-search-index.ts",
    "build:docker": "docker compose up --build --force-recreate -d",
    "check": "pnpm tsc --noEmit",
    "dev": "vinxi dev",
    "lint": "biome check --write .",
    "preview": "vinxi start",
    "prepare": "husky || true"
  },
  "dependencies": {
    "@solidjs/meta": "^0.29.4",
    "@solidjs/router": "^0.15.0",
    "@solidjs/start": "1.3.2",
    "lucide-solid": "^1.14.0",
    "minisearch": "^7.2.0",
    "solid-js": "^1.9.5",
    "vinxi": "^0.5.7"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.14",
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^25.6.2",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.2",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3"
  },
  "lint-staged": {
    "*.{js,ts,jsx,tsx,json,jsonc,css,html,md,yml,yaml}": "biome check --write --no-errors-on-unmatched"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@11.1.0"
}
