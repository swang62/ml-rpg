 negatives","fontSize":13,"fontFamily":2,"createdAt":"2026-06-23T01:52:10.946Z","updatedAt":"2026-06-23T01:52:10.946Z","version":1},{"id":"ss_desc3","type":"text","x":45,"y":255,"text":"scores = u @ [v_pos, v_neg1, ..., v_negK]","fontSize":13,"fontFamily":2,"createdAt":"2026-06-23T01:52:10.946Z","updatedAt":"2026-06-23T01:52:10.946Z","version":1},{"id":"ss_desc4","type":"text","x":45,"y":275,"text":"probs = softmax(scores) across 1+K items","fontSize":13,"fontFamily":2,"createdAt":"2026-06-23T01:52:10.946Z","updatedAt":"2026-06-23T01:52:10.946Z","version":1},{"id":"ss_desc5","type":"text","x":45,"y":295,"text":"loss = -log(probs[0])  (target = positive)","fontSize":13,"fontFamily":2,"createdAt":"2026-06-23T01:52:10.946Z","updatedAt":"2026-06-23T01:52:10.946Z","version":1},{"id":"ln_desc1","type":"text","x":430,"y":215,"text":"Full candidate list (e.g., top-100):","fontSize":13,"fontFamily":2,"createdAt":"2026-06-23T01:52:10.946Z","updatedAt":"2026-06-23T01:52:10.946Z","version":1},{"id":"ln_desc2","type":"text","x":430,"y":235,"text":"Model predicts score s_i for each item","fontSize":13,"fontFamily":2,"createdAt":"2026-06-23T01:52:10.946Z","updatedAt":"2026-06-23T01:52:10.946Z","version":1},{"id":"ln_desc3","type":"text","x":430,"y":255,"text":"Target distribution: softmax(labels)","fontSize":13,"fontFamily":2,"createdAt":"2026-06-23T01:52:10.946Z","updatedAt":"2026-06-23T01:52:10.946Z","version":1},{"id":"ln_desc4","type":"text","x":430,"y":275,"text":"Predicted dist: softmax(model_scores)","fontSize":13,"fontFamily":2,"createdAt":"2026-06-23T01:52:10.946Z","updatedAt":"2026-06-23T01:52:10.946Z","version":1},{"id":"ln_desc5","type":"text","x":430,"y":295,"text":"loss = KL(target_dist || pred_dist)","fontSize":13,"fontFamily":2,"createdAt":"2026-06-23T01:52:10.946Z","updatedAt":"2026-06-23T01:52:10.946Z","version":1},{"id":"lr_desc1","type":"text","x":815,"y":215,"text":"For every PAIR of items (i, j):","fontSize":13,"fontFamily":2,"createdAt":"2026-06-23T01:52:10.946Z","updatedAt":"2026-06-23T01:52:10.946Z","version":1},{"id":"lr_desc2","type":"text","x":815,"y":235,"text":"If label_i > label_j, we want s_i > s_j","fontSize":13,"fontFamily":2,"createdAt":"2026-06-23T01:52:10.946Z","updatedAt":"2026-06-23T01:52:10.946Z","version":1},{"id":"lr_desc3","type":"text","x":815,"y":255,"text":"Pairwise logistic loss:","fontSize":13,"fontFamily":2,"createdAt":"2026-06-23T01:52:10.946Z","updatedAt":"2026-06-23T01:52:10.946Z","version":1},{"id":"lr_desc4","type":"text","x":815,"y":275,"text":"L_ij = log(1 + exp(-(s_i - s_j)))","fontSize":13,"fontFamily":2,"createdAt":"2026-06-23T01:52:10.946Z","updatedAt":"2026-06-23T01:52:10.946Z","version":1},{"id":"lr_desc5","type":"text","x":815,"y":295,"text":"Weighted by |ΔNDCG| if i and j swap","fontSize":13,"fontFamily":2,"createdAt":"2026-06-23T01:52:10.946Z","updatedAt":"2026-06-23T01:52:10.946Z","version":1},{"id":"ss_formula","type":"text","x":45,"y":340,"strokeColor":"#1971c2","text":"Loss formula:","fontSize":16,"fontFamily":2,"createdAt":"2026-06-23T01:52:10.946Z","updatedAt":"2026-06-23T01:52:10.946Z","version":1},{"id":"ln_formula","type":"text","x":430,"y":340,"strokeColor":"#2f9e44","text":"Loss formula:","fontSize":16,"fontFamily":2,"createdAt":"2026-06-23T01:52:10.946Z","updatedAt":"2026-06-23T01:52:10.946Z","version":1},{"id":"lr_formula","type":"text","x":815,"y":340,"strokeColor":"#e8590c","text":"Loss formula:","fontSize":16,"fontFamily":2,"createdAt":"2026-06-23T01:52:10.946Z","updatedAt":"2026-06-23T01:52:10.946Z","version":1},{"id":"ss_eq","type":"text","x":45,"y":365,"text":"L = -log(  exp(s_pos) / Σ exp(s_i)  )","fontSize":14,"fontFamily":2,"createdAt":"2026-06-23T01:52:10.946Z","updatedAt":"2026-06-23T01:52:10.946Z","version":1},{"id":"ln_eq","type":"text","x":430,"y":365,"text":"L = -Σ  target_i * log(pred_i)","fontSize":14,"fontFamily":2,"createdAt":"2026-06-23T01:52:10.946Z","updatedAt":"2026-06-23T01:52:10.946Z","version":1},{"id":"ln_eq2","type":"text","x":430,"y":385,"text":"where target = softmax(relevance_labels)","fontSize":12,"fontFamily":2,"createdAt":"2026-06-23T01:52:10.946Z","updatedAt":"2026-06-23T01:52:10.946Z","version":1},{"id":"ln_eq3","type":"text","x":430,"y":405,"text":"pred = softmax(model_scores)","fontSize":12,"fontFamily":2,"createdAt":"2026-06-23T01:52:10.946Z","updatedAt":"2026-06-23T01:52:10.946Z","version":1},{"id":"lr_eq","type":"text","x":815,"y":365,"text":"L = Σ_{i<j} |ΔNDCG_{ij}| * L_ij","fontSize":14,"fontFamily":2,"createdAt":"2026-06-23T01:52:10.946Z","updatedAt":"2026-06-23T01:52:10.946Z","version":1},{"id":"lr_eq2","type":"text","x":815,"y":385,"text":"L_ij = log(1 + exp(-(s_i - s_j)))","fontSize":12,"fontFamily":2,"createdAt":"2026-06-23T01:52:10.946Z","updatedAt":"2026-06-23T01:52:10.946Z","version":1},{"id":"lr_eq3","type":"text","x":815,"y":405,"text":"ΔNDCG = change in NDCG if i↔j swap","fontSize":12,"fontFamily":2,"createdAt":"2026-06-23T01:52:10.946Z","updatedAt":"2026-06-23T01:52:10.946Z","version":1},{"id":"ss_neg","type":"text","x":45,"y":420,"text":"Negatives: Sampled (random, in-batch, freq)","fontSize":13,"fontFamily":2,"createdAt":"2026-06-23T01:52:10.946Z","updatedAt":"2026-06-23T01:52:10.946Z","version":1},{"id":"ln_neg","type":"text","x":430,"y":425,"text":"Negatives: Natural — all items < positive","fontSize":13,"fontFamily":2,"createdAt":"2026-06-23T01:52:10.946Z","updatedAt":"2026-06-23T01:52:10.946Z","version":1},{"id":"lr_neg","type":"text","x":815,"y":425,"text":"Negatives: Natural — items with lower label","fontSize":13,"fontFamily":2,"createdAt":"2026-06-23T01:52:10.946Z","updatedAt":"2026-06-23T01:52:10.946Z","version":1},{"id":"ss_pros","type":"text","x":45,"y":460,"strokeColor":"#2f9e44","text":"Pros:","fontSize":16,"fontFamily":2,"createdAt":"2026-06-23T01:52:10.946Z","updatedAt":"2026-06-23T01:52:10.946Z","version":1},{"id":"ln_pros","type":"text","x":430,"y":460,"strokeColor":"#2f9e44","text":"Pros:","fontSize":16,"fontFamily":2,"createdAt":"2026-06-23T01:52:10.946Z","updatedAt":"2026-06-23T01:52:10.946Z","version":1},{"id":"lr_pros","type":"text","x":815,"y":460,"strokeColor":"#2f9e44","text":"Pros:","fontSize":16,"fontFamily":2,"createdAt":"2026-06-23T01:52:10.946Z","updatedAt":"2026-06-23T01:52:10.946Z","version":1},{"id":"ss_pros1","type":"text","x":45,"y":485,"text":"✓ Scales to billions of items","fontSize":12,"fontFamily":2,"createdAt":"2026-06-23T01:52:10.946Z","updatedAt":"2026-06-23T01:52:10.946Z","version":1},{"id":"ss_pros2","type":"text","x":45,"y":505,"text":"✓ Efficient via in-batch negatives","fontSize":12,"fontFamily":2,"createdAt":"2026-06-23T01:52:10.946Z","updatedAt":"2026-06-23T01:52:10.946Z","version":1},{"id":"ss_pros3","type":"text","x":45,"y":525,"text":"✓ Works with pure implicit data","fontSize":12,"fontFamily":2,"createdAt":"2026-06-23T01:52:10.946Z","updatedAt":"2026-06-23T01:52:10.946Z","version":1},{"id":"ln_pros1","type":"text","x":430,"y":485,"text":"✓ Directly optimizes top-1 accuracy","fontSize":12,"fontFamily":2,"createdAt":"2026-06-23T01:52:10.946Z","updatedAt":"2026-06-23T01:52:10.946Z","version":1},{"id":"ln_pros2","type":"text","x":430,"y":505,"text":"✓ Handles graded relevance naturally","fontSize":12,"fontFamily":2,"createdAt":"2026-06-23T01:52:10.946Z","updatedAt":"2026-06-23T01:52:10.946Z","version":1},{"id":"ln_pros3","type":"text","x":430,"y":525,"text":"✓ Simple implementation","fontSize":12,"fontFamily":2,"createdAt":"2026-06-23T01:52:10.946Z","updatedAt":"2026-06-23T01:52:10.946Z","version":1},{"id":"lr_pros1","type":"text","x":815,"y":485,"text":"✓ Optimizes NDCG directly (ΔNDCG weight)","fontSize":12,"fontFamily":2,"createdAt":"2026-06-23T01:52:10.946Z","updatedAt":"2026-06-23T01:52:10.946Z","version":1},{"id":"lr_pros2","type":"text","x":815,"y":505,"text":"✓ Best at top-k precision where rank matters","fontSize":12,"fontFamily":2,"createdAt":"2026-06-23T01:52:10.946Z","updatedAt":"2026-06-23T01:52:10.946Z","version":1},{"id":"ss_cons","type":"text","x":45,"y":555,"strokeC